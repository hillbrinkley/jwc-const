---
import '../styles/global.css';
---

<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<meta name='viewport' content='width=device-width' />
		<meta name='generator' content={Astro.generator} />
		<title>JWC Construction LLC | Garages, Decks & Home Additions in Bedford, VA</title>
		<meta
			name='description'
			content='JWC Construction LLC builds high-quality residential garages, decks, and home additions in Bedford, VA. Durable craftsmanship and dependable construction. Call (434) 907-3052.'
		/>
		<meta
			name='keywords'
			content='construction Bedford VA, garage builder Bedford Virginia, deck builder Bedford VA, home additions Bedford VA, JWC Construction'
		/>
		<link rel='canonical' href='https://www.jwcbedford.com/' />

		<!-- Open Graph -->
		<meta property='og:title' content='JWC Construction LLC | Bedford, VA' />
		<meta
			property='og:description'
			content='Residential garages, decks, and home additions in Bedford, VA. Quality craftsmanship you can count on.'
		/>
		<meta property='og:url' content='https://www.jwcbedford.com/' />
		<meta property='og:type' content='website' />
		<meta property='og:image' content='https://www.jwcbedford.com/og-image.jpg' />

		<!-- Twitter Card -->
		<meta name='twitter:card' content='summary_large_image' />
		<meta name='twitter:title' content='JWC Construction LLC | Bedford, VA' />
		<meta
			name='twitter:description'
			content='Residential garages, decks, and home additions in Bedford, VA.'
		/>
		<script type='application/ld+json'>
			{
				"@context": "https://schema.org",
				"@type": "LocalBusiness",
				"name": "JWC Construction LLC",
				"description": "Residential garage, deck, and home addition contractor in Bedford, VA.",
				"url": "https://www.jwcbedford.com",
				"telephone": "+14349073052",
				"email": "josh@jwcbedford.com",
				"address": {
					"@type": "PostalAddress",
					"addressLocality": "Bedford",
					"addressRegion": "VA",
					"addressCountry": "US"
				},
				"areaServed": {
					"@type": "City",
					"name": "Bedford"
				},
				"serviceType": ["Garage Construction", "Deck Building", "Home Additions"],
				"priceRange": "$$"
			}
		</script>
	</head>
	<body class='grid justify-center items-center bg-green-900 sm:h-screen'>
		<div class='text-white grid gap-10 sm:p-20 p-5 border-2'>
			<h1 class='sr-only'>
				JWC Construction LLC — Garage, Deck & Home Addition Contractor in Bedford, VA
			</h1>
			<img src='/smaller.svg' alt='JWC Construction LLC logo' class='invert' />
			<p class='text-pretty max-w-3xl'>
				We specialize in building high-quality residential garages, decks, and home
				additions. We focus on durable craftsmanship, practical design, and dependable
				construction that adds real value and usable space to your home.
			</p>
			<a class='hover:underline' href='/values'>Our Values </a>
			<span>Call us: <a href='tel:4349073052' class='hover:underline'>(434) 907-3052</a></span>

			<span
				>Email us: <a href='mailto:josh@jwcbedford.com' class='hover:underline'
					>josh@jwcbedford.com</a
				></span
			>
		</div>
	</body>
</html>
